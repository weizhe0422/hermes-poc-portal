def _properties(testcase: ET.Element) -> dict[str, str]:
    properties: dict[str, str] = {}
    node = testcase.find("properties")
    if node is None:
        return properties
    for item in node.findall("property"):
        name = item.get("name")
        if name:
            properties[name] = item.get("value", item.text or "")
    return properties


def _case_result(testcase: ET.Element, source: Path) -> dict[str, Any]:
    properties = _properties(testcase)
    failure = testcase.find("failure")
    error = testcase.find("error")
    skipped = testcase.find("skipped")
    if failure is not None or error is not None:
        execution_status = "FAILED"
        detail_node = failure if failure is not None else error
        detail = (detail_node.get("message") or detail_node.text or "")[:2000]
    elif skipped is not None:
        execution_status = "SKIPPED"
        detail = (skipped.get("message") or skipped.text or "")[:2000]
    else:
        execution_status = "PASSED"
        detail = ""
    requirement_text = properties.get("requirement_ids", "")
    coverage_claim = properties.get("hermes.coverage_claim", "")
    failure_classification = properties.get("failure_classification", "")
    status = execution_status
    if execution_status == "FAILED" and failure_classification == "BLOCKED_BY_CONTRACT":
        status = "BLOCKED_BY_CONTRACT"
    if coverage_claim == "none" and execution_status != "FAILED":
        status = "NOT_EVALUATED"
    try:
        duration_seconds = float(testcase.get("time", "0") or 0)
    except ValueError as exc:
        raise ValueError(
            f"{properties.get('test_case_id', testcase.get('name', 'UNKNOWN'))}: "
            "testcase time is not numeric"
        ) from exc
    if not math.isfinite(duration_seconds) or duration_seconds < 0:
        raise ValueError(
            f"{properties.get('test_case_id', testcase.get('name', 'UNKNOWN'))}: "
            "testcase time must be finite and non-negative"
        )
    return {
        "test_case_id": properties.get("test_case_id", "UNKNOWN"),
        "requirement_ids": [
            item.strip() for item in requirement_text.split(",") if item.strip()
        ],
        "critical": properties.get("critical", "false").lower() == "true",
        "critical_metadata": properties.get("critical", ""),
        "status": status,
        "execution_status": execution_status,
        "case_source": properties.get("hermes.case_source", ""),
        "coverage_claim": coverage_claim,
        "acceptance_status": properties.get("hermes.acceptance_status", ""),
        "golden_status": properties.get("hermes.golden_status", ""),
        "evidence_kind": properties.get("hermes.evidence_kind", ""),
        "engine_evidence": properties.get("engine_evidence"),
        "engine_evidence_file": properties.get("engine_evidence_file"),
        "outer_evidence": properties.get("outer_evidence"),
        "outer_evidence_file": properties.get("outer_evidence_file"),
        "failure_classification": failure_classification,
        "name": testcase.get("name", ""),
        "classname": testcase.get("classname", ""),
        "duration_seconds": duration_seconds,
        "detail": detail,
        "junit_source": str(source),
    }


def _canonical_junit_paths(run_root: Path) -> list[Path]:
    junit_root = run_root / "junit"
    manifest, _error = _read_json_object(run_root / "manifest.yaml")
    suite = manifest.get("test_suite") if manifest is not None else None
    if suite == "portal-e2e":
        source_search_root = run_root / "portal-e2e" / "junit"
        source_paths = sorted(
            path
            for path in source_search_root.rglob("*.xml")
            if path.is_file() and not path.is_symlink()
        )
    elif suite == "controller-e2e":
        source_search_root = run_root / "controller-e2e"
        source_paths = sorted(
            path
            for path in source_search_root.rglob("*.xml")
            if path.is_file()
            and not path.is_symlink()
            and "execution-probe" not in path.parts
        )
    else:
        source_paths = sorted(
            path
            for path in run_root.rglob("*.xml")
            if path.is_file()
            and not path.is_symlink()
            and junit_root not in path.parents
        )
    if not source_paths:
        return sorted(
            path
            for path in junit_root.glob("*.xml")
            if path.is_file() and not path.is_symlink()
        )

    junit_root.mkdir(parents=True, exist_ok=True)
    for stale in junit_root.glob("*.xml"):
        stale.unlink()
    canonical: list[Path] = []
    for source in source_paths:
        relative = source.relative_to(run_root)
        stem_parts = [*relative.parts[:-1], relative.stem]
        safe_name = "-".join(
            _SAFE_JUNIT_SEGMENT.sub("-", part).strip("-") for part in stem_parts
        )
        destination = junit_root / f"{safe_name}.xml"
        shutil.copyfile(source, destination)
        canonical.append(destination)
    return canonical


def _metadata_errors(case: dict[str, Any]) -> list[str]:
    errors = []
    if case["test_case_id"] == "UNKNOWN" or not case["test_case_id"]:
        errors.append(f"{case['name']}: missing test_case_id JUnit property")
    elif not _TEST_CASE_ID.fullmatch(case["test_case_id"]):
        errors.append(f"{case['test_case_id']}: invalid Test Case ID format")
    if not case["requirement_ids"]:
        errors.append(f"{case['test_case_id']}: missing requirement_ids JUnit property")
    for requirement_id in case["requirement_ids"]:
        if not _REQUIREMENT_ID.fullmatch(requirement_id):
            errors.append(
                f"{case['test_case_id']}: invalid Requirement ID {requirement_id!r}"
            )
    if case["critical_metadata"] not in {"true", "false"}:
        errors.append(f"{case['test_case_id']}: missing or invalid critical property")
    expected_requirements = _CASE_REQUIREMENTS.get(case["test_case_id"])
    if expected_requirements is None:
        errors.append(
            f"{case['test_case_id']}: case is not approved for the T-M0/T-M1 suite"
        )
    elif case["requirement_ids"] and tuple(case["requirement_ids"]) != expected_requirements:
        errors.append(
            f"{case['test_case_id']}: Requirement mapping must be "
            f"{','.join(expected_requirements)}"
        )

    if case["test_case_id"] in _RUNTIME_CASES:
        expected_runtime_metadata = {
            "case_source": "frozen-runtime-case",
            "coverage_claim": "case-level",
            "acceptance_status": "case-evaluated",
            "golden_status": "frozen-v0.2.0",
            "evidence_kind": "black-box",
            "critical_metadata": "true",
        }
        for field, expected in expected_runtime_metadata.items():
            if case[field] != expected:
                errors.append(
                    f"{case['test_case_id']}: {field} must equal {expected!r}"
                )
    elif case["test_case_id"] in _INFRASTRUCTURE_EVIDENCE:
        expected_infrastructure_metadata = {
            "case_source": "frozen-infrastructure-case",
            "coverage_claim": "case-level",
            "acceptance_status": "case-evaluated",
            "golden_status": "frozen-v0.2.0",
            "evidence_kind": _INFRASTRUCTURE_EVIDENCE[case["test_case_id"]],
            "critical_metadata": "true",
        }
        for field, expected in expected_infrastructure_metadata.items():
            if case[field] != expected:
                errors.append(
                    f"{case['test_case_id']}: {field} must equal {expected!r}"
                )
    if case["test_case_id"] in _ENGINE_EVIDENCE_CASES:
        if case["engine_evidence"] not in {"PASS", "FAIL"}:
            errors.append(
                f"{case['test_case_id']}: isolated Engine evidence is missing"
            )
        elif (
            case["engine_evidence"] == "FAIL"
            and case["execution_status"] != "FAILED"
        ):
            errors.append(
                f"{case['test_case_id']}: failed Engine evidence lacks a JUnit failure"
            )
        expected_engine_file = f"evidence-{case['test_case_id']}.json"
        if case["engine_evidence_file"] != expected_engine_file:
            errors.append(
                f"{case['test_case_id']}: engine_evidence_file must equal "
                f"{expected_engine_file!r}"
            )
    outer_evidence_file = _OUTER_EVIDENCE_FILES.get(case["test_case_id"])
    if outer_evidence_file is not None:
        if case["outer_evidence"] != "PASS":
            errors.append(
                f"{case['test_case_id']}: outer orchestration evidence is missing or failed"
            )
        if case["outer_evidence_file"] != outer_evidence_file:
            errors.append(
                f"{case['test_case_id']}: outer_evidence_file must equal "
                f"{outer_evidence_file!r}"
            )
    return errors


def _manifest_errors(run_root: Path, run_id: str) -> list[str]:
    path = run_root / "manifest.yaml"
    if not path.is_file():
        return ["manifest.yaml is missing"]
    if path.is_symlink():
        return ["manifest.yaml must not be a symbolic link"]
    try:
        manifest = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        return [f"manifest.yaml is not valid JSON-compatible YAML: {exc}"]
    if not isinstance(manifest, dict):
        return ["manifest.yaml root must be an object"]

    errors = []
    expected = {
        "run_id": run_id,
        "fixture_type": "SYNTHETIC",
        "spec_version": "0.1.0",
        "contract_tag": _FROZEN_CONTRACT_TAG,
        "contract_commit": _FROZEN_CONTRACT_COMMIT,
        "contract_version": _FROZEN_CONTRACT_VERSION,
    }
    for name, value in expected.items():
        if manifest.get(name) != value:
            errors.append(f"manifest.{name} must equal {value!r}")
    if manifest.get("test_suite") not in {"controller-e2e", "portal-e2e"}:
        errors.append("manifest.test_suite is invalid")
    git_commit = manifest.get("git_commit")
    if not isinstance(git_commit, str) or not re.fullmatch(r"[0-9a-f]{40}", git_commit):
        errors.append("manifest.git_commit must be a 40-character lowercase commit")
    if manifest.get("git_branch") != "test/t-m0-m1":
        errors.append("manifest.git_branch must equal 'test/t-m0-m1'")
    platform_commit = manifest.get("platform_commit")
    if not isinstance(platform_commit, str) or not re.fullmatch(
        r"[0-9a-f]{40}", platform_commit
    ):
        errors.append("manifest.platform_commit must be a 40-character lowercase commit")
    images = manifest.get("images")
    if not isinstance(images, dict) or not images or not all(
        isinstance(value, str) and value for value in images.values()
    ):
        errors.append("manifest.images must contain non-empty image references")
    expected_image_roles = _SUITE_IMAGE_ROLES.get(manifest.get("test_suite"))
    if isinstance(images, dict) and expected_image_roles is not None:
        actual_image_roles = set(images)
        if actual_image_roles != expected_image_roles:
            errors.append(
                "manifest.images roles must equal "
                + ",".join(sorted(expected_image_roles))
            )
    image_ids = manifest.get("image_ids")
    if not isinstance(image_ids, dict) or not image_ids or not all(
        isinstance(value, str) and re.fullmatch(r"sha256:[0-9a-f]{64}", value)
        for value in image_ids.values()
    ):
        errors.append("manifest.image_ids must contain immutable sha256 image IDs")
    elif isinstance(images, dict) and set(image_ids) != set(images):
        errors.append("manifest.image_ids keys must match manifest.images keys")
    executed_at = manifest.get("executed_at")
    if not isinstance(executed_at, str) or not _RFC3339_UTC.fullmatch(executed_at):
        errors.append("manifest.executed_at must be a UTC RFC 3339 timestamp")
    return errors


def _inventory_errors(
    run_root: Path,
    cases: list[dict[str, Any]],
) -> list[str]:
    try:
        manifest = json.loads((run_root / "manifest.yaml").read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return []
    expected = _SUITE_CASES.get(manifest.get("test_suite"))
    if expected is None:
        return []
    counts = Counter(case["test_case_id"] for case in cases)
    actual = set(counts)
    errors = []
    missing = sorted(expected - actual)
    unexpected = sorted(actual - expected)
    duplicates = sorted(case_id for case_id, count in counts.items() if count != 1)
    if missing:
        errors.append(f"suite inventory is missing cases: {','.join(missing)}")
    if unexpected:
        errors.append(f"suite inventory has unexpected cases: {','.join(unexpected)}")
    if duplicates:
        errors.append(f"suite inventory has duplicate cases: {','.join(duplicates)}")
    return errors


def _portal_infrastructure_evidence_errors(path: Path) -> list[str]:
    evidence, read_error = _read_json_object(path)
    if read_error:
        return [f"invalid JSON artifact portal-e2e/infrastructure-evidence.json: {read_error}"]
    assert evidence is not None
    errors: list[str] = []
    if evidence.get("schema_version") != "0.2.0":
        errors.append("portal infrastructure evidence schema_version is invalid")
    if evidence.get("contract_tag") != _FROZEN_CONTRACT_TAG:
        errors.append("portal infrastructure evidence contract_tag is invalid")
    records = evidence.get("cases")
    expected_ids = {
        "SECURITY-001",
        "SECURITY-002",
        "SECURITY-003",
        "EXECUTION-004",
        "ARTIFACT-001",
    }
    if not isinstance(records, dict) or set(records) != expected_ids:
        return [*errors, "portal infrastructure evidence inventory is invalid"]

    expected_values = {
        "SECURITY-001": {
            "portal_running": True,
            "controller_running": True,
            "hermes_running": True,
            "host_ports_published": [8080],
            "controller_published": False,
            "hermes_published": False,
            "verdict": True,
        },
        "SECURITY-002": {
            "is_independent_container": True,
            "networks": ["e2e-network"],
            "can_connect_portal": True,
            "can_connect_controller": False,
            "can_connect_hermes": False,
            "verdict": True,
        },
        "SECURITY-003": {
            "has_docker_socket": False,
            "has_knowledge_mount": False,
            "has_skill_mount": False,
            "has_formal_volume": False,
            "has_writable_source_mount": False,
            "can_access_git_metadata": False,
            "verdict": True,
        },
        "EXECUTION-004": {
            "git_status_unchanged": True,
            "runner_has_git_metadata": False,
            "runner_has_writable_source": False,
            "only_gitignore_artifacts_allowed": True,
            "verdict": True,
        },
    }
    for case_id, fields in expected_values.items():
        record = records.get(case_id)
        if not isinstance(record, dict):
            errors.append(f"{case_id} outer evidence must be an object")
            continue
        for field, expected in fields.items():
            if record.get(field) != expected:
                errors.append(
                    f"{case_id} outer evidence {field} must equal {expected!r}"
                )

    artifact = records.get("ARTIFACT-001")
    if not isinstance(artifact, dict):
        errors.append("ARTIFACT-001 outer evidence must be an object")
    else:
        for field in (
            "written_to_independent_volume",
            "readable_after_runner_exit",
            "verdict",
        ):
            if artifact.get(field) is not True:
                errors.append(f"ARTIFACT-001 outer evidence {field} must equal True")
        required_files = artifact.get("required_files_present")
        if not isinstance(required_files, dict) or {
            "manifest",
            "summary",
            "junit",
        } - {name for name, value in required_files.items() if value is True}:
            errors.append(
                "ARTIFACT-001 outer evidence required_files_present is incomplete"
            )
        if not isinstance(artifact.get("trace_paths"), list) or not artifact["trace_paths"]:
            errors.append("ARTIFACT-001 outer evidence trace_paths must be non-empty")
        if not isinstance(artifact.get("log_paths"), list) or not artifact["log_paths"]:
            errors.append("ARTIFACT-001 outer evidence log_paths must be non-empty")
        if artifact.get("secret_findings") != []:
            errors.append("ARTIFACT-001 outer evidence secret_findings must be empty")
    return errors


def _controller_environment_evidence_errors(path: Path) -> list[str]:
    evidence, read_error = _read_json_object(path)
    relative = "controller-e2e/docker-snapshots/controller-environment.json"
    if read_error:
        return [f"invalid JSON artifact {relative}: {read_error}"]
    assert evidence is not None
    errors: list[str] = []
    if evidence.get("schema_version") != "0.2.0":
        errors.append("controller environment evidence schema_version is invalid")
    if evidence.get("contract_tag") != _FROZEN_CONTRACT_TAG:
        errors.append("controller environment evidence contract_tag is invalid")
    record = evidence.get("case")
    expected = {
        "test_case_id": "CONTROLLER-ENV-001",
        "is_independent_container": True,
        "uses_isolated_docker_engine": True,
        "has_docker_socket": False,
        "can_affect_dev_or_prod_containers": False,
        "cleanup_limited_to_run_id": True,
        "verdict": True,
    }
    if not isinstance(record, dict):
        return [*errors, "controller environment evidence case is invalid"]
    for field, value in expected.items():
        if record.get(field) != value:
            errors.append(
                f"CONTROLLER-ENV-001 outer evidence {field} must equal {value!r}"
            )
    return errors


def _artifact_errors(run_root: Path, cases: list[dict[str, Any]]) -> list[str]:
    try:
        manifest = json.loads((run_root / "manifest.yaml").read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return []
    suite = manifest.get("test_suite")
    if suite == "controller-e2e":
        required = (
            "controller-e2e/logs/docker-engine-test.log",
            "controller-e2e/docker-snapshots/containers.jsonl",
            "controller-e2e/docker-snapshots/persistence.json",
            "controller-e2e/docker-snapshots/cleanup.json",
            "controller-e2e/docker-snapshots/outer-cleanup.json",
            "controller-e2e/docker-snapshots/controller-environment.json",
            "controller-e2e/phase-status.jsonl",
            "controller-e2e/runner-status.json",
            "controller-e2e/runtime-008/engine-context.json",
        ) + tuple(
            f"controller-e2e/docker-snapshots/{prefix}-{case_id}.{suffix}"
            for case_id in sorted(_ENGINE_EVIDENCE_CASES)
            for prefix, suffix in (("evidence", "json"), ("events", "jsonl"))
        ) + tuple(
            path
            for case_id in sorted(_RUNTIME_CASES)
            for path in (
                f"controller-e2e/logs/controller-{case_id.lower()}.log",
                f"controller-e2e/{case_id.lower()}/summary.json",
                f"controller-e2e/{case_id.lower()}/summary.md",
                f"controller-e2e/{case_id.lower()}/http-trace.jsonl",
            )
        )
        checks = (
            ("controller-e2e/docker-snapshots/cleanup.json", "cleanup_verified"),
            (
                "controller-e2e/docker-snapshots/outer-cleanup.json",
                "compose_down_verified",
            ),
            ("controller-e2e/runner-status.json", "orchestration_completed"),
            (
                "controller-e2e/runner-status.json",
                "evidence_collection_verified",
            ),
            ("controller-e2e/runner-status.json", "cleanup_verified"),
            ("controller-e2e/runner-status.json", "compose_down_verified"),
            ("controller-e2e/runner-status.json", "source_tree_unchanged"),
        )
        nonempty = (
            "controller-e2e/logs/docker-engine-test.log",
            "controller-e2e/docker-snapshots/containers.jsonl",
            "controller-e2e/phase-status.jsonl",
            "controller-e2e/runtime-008/engine-context.json",
        ) + tuple(
            f"controller-e2e/docker-snapshots/events-{case_id}.jsonl"
            for case_id in sorted(
                _ENGINE_EVIDENCE_CASES
                - {"RUNTIME-006", "RUNTIME-007", "RUNTIME-012", "RUNTIME-013"}
            )
        ) + tuple(
            path
            for case_id in sorted(_RUNTIME_CASES)
            for path in (
                f"controller-e2e/logs/controller-{case_id.lower()}.log",
                f"controller-e2e/{case_id.lower()}/summary.json",
                f"controller-e2e/{case_id.lower()}/summary.md",
                f"controller-e2e/{case_id.lower()}/http-trace.jsonl",
            )
        )
    elif suite == "portal-e2e":
        required = (
            "portal-e2e/compose.log",
            "portal-e2e/metadata.json",
            "portal-e2e/playwright-report/index.html",
            "portal-e2e/preflight/artifact-write-probe.json",
            "portal-e2e/infrastructure-evidence.json",
            "portal-e2e/cleanup.json",
            "portal-e2e/runner-status.json",
        )
        checks = (
            ("portal-e2e/cleanup.json", "compose_down_verified"),
            ("portal-e2e/runner-status.json", "orchestration_completed"),
            ("portal-e2e/runner-status.json", "runner_passed"),
            ("portal-e2e/runner-status.json", "compose_logs_verified"),
            ("portal-e2e/runner-status.json", "cleanup_verified"),
            ("portal-e2e/runner-status.json", "source_tree_unchanged"),
        )
        nonempty = (
            "portal-e2e/compose.log",
            "portal-e2e/metadata.json",
            "portal-e2e/playwright-report/index.html",
            "portal-e2e/preflight/artifact-write-probe.json",
        )
    else:
        return []

    errors = [
        f"symbolic-link artifact is forbidden: {path.relative_to(run_root)}"
        for path in run_root.rglob("*")
        if path.is_symlink()
    ]
    errors.extend(
        f"required artifact is missing: {path}"
        for path in required
        if not (run_root / path).is_file()
    )
    errors.extend(
        f"required artifact is empty: {path}"
        for path in nonempty
        if (run_root / path).is_file() and (run_root / path).stat().st_size == 0
    )
    for relative, field in checks:
        path = run_root / relative
        if not path.is_file():
            continue
        try:
            document = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as exc:
            errors.append(f"invalid JSON artifact {relative}: {exc}")
            continue
        if document.get(field) is not True:
            errors.append(f"artifact check failed: {relative}#{field}")

    if suite == "controller-e2e":
        runner_status_path = run_root / "controller-e2e/runner-status.json"
        if runner_status_path.is_file():
            try:
                runner_status = json.loads(
                    runner_status_path.read_text(encoding="utf-8")
                )
            except (OSError, json.JSONDecodeError):
                pass
            else:
                runtime_cases = [
                    case for case in cases if case["test_case_id"] in _RUNTIME_CASES
                ]
                all_runtime_passed = runtime_cases and all(
                    case["status"] == "PASSED" for case in runtime_cases
                )
                runtime_execution_failed = any(
                    case["execution_status"] == "FAILED" for case in runtime_cases
                )
                if all_runtime_passed and runner_status.get("runner_passed") is not True:
                    errors.append(
                        "artifact check failed: "
                        "controller-e2e/runner-status.json#runner_passed"
                    )
                elif (
                    runtime_execution_failed
                    and runner_status.get("runner_passed") is not False
                ):
                    errors.append(
                        "controller runner status disagrees with Runtime JUnit failures"
                    )

    if suite == "controller-e2e":
        snapshots = run_root / "controller-e2e/docker-snapshots"
        runtime_008_context, runtime_008_context_error = _read_json_object(
            run_root / "controller-e2e/runtime-008/engine-context.json"
        )
        runtime_008_engine_observation: str | None = None
        if runtime_008_context_error:
            errors.append(
                "RUNTIME-008 Engine context is invalid: "
                + runtime_008_context_error
            )
        else:
            (
                runtime_008_engine_observation,
                context_validation_error,
            ) = _runtime_008_context_observation(runtime_008_context)
            if context_validation_error:
                errors.append(context_validation_error)
        cases_by_id = {case["test_case_id"]: case for case in cases}
        for case_id in sorted(_ENGINE_EVIDENCE_CASES):
            evidence_path = snapshots / f"evidence-{case_id}.json"
            if not evidence_path.is_file():
                continue
            try:
                evidence = json.loads(evidence_path.read_text(encoding="utf-8"))
            except (OSError, json.JSONDecodeError) as exc:
                errors.append(f"invalid Engine evidence for {case_id}: {exc}")
                continue
            if evidence.get("test_case_id") != case_id:
                errors.append(f"{case_id} Engine evidence Test Case ID is invalid")
            verdict = evidence.get("verdict")
            if not isinstance(verdict, bool):
                errors.append(f"{case_id} Engine evidence verdict is invalid")
            else:
                expected_junit_evidence = "PASS" if verdict else "FAIL"
                case = cases_by_id.get(case_id)
                if (
                    case is not None
                    and case.get("engine_evidence") != expected_junit_evidence
                ):
                    errors.append(
                        f"{case_id} Engine evidence verdict disagrees with JUnit"
                    )
            if (
                case_id == "RUNTIME-008"
                and runtime_008_engine_observation is not None
                and evidence.get("winning_action")
                != runtime_008_engine_observation
            ):
                errors.append(
                    "RUNTIME-008 Engine evidence winner differs from API context"
                )

    if suite == "portal-e2e":
        metadata_path = run_root / "portal-e2e/metadata.json"
        if metadata_path.is_file():
            try:
                metadata = json.loads(metadata_path.read_text(encoding="utf-8"))
            except (OSError, json.JSONDecodeError) as exc:
                errors.append(f"invalid JSON artifact portal-e2e/metadata.json: {exc}")
            else:
                records = metadata.get("cases")
                if (
                    metadata.get("report_type")
                    != "hermes.portal-e2e.frozen-infrastructure-execution"
                ):
                    errors.append("portal metadata report_type is invalid")
                if not isinstance(records, list):
                    errors.append("portal metadata cases must be an array")
                elif not all(
                    isinstance(record, dict)
                    and isinstance(record.get("case_id"), str)
                    for record in records
                ):
                    errors.append("portal metadata contains an invalid case record")
                else:
                    metadata_ids = sorted(record["case_id"] for record in records)
                    junit_ids = sorted(case["test_case_id"] for case in cases)
                    if metadata_ids != junit_ids:
                        errors.append(
                            "portal metadata Test Case IDs do not match JUnit"
                        )
        evidence_path = run_root / "portal-e2e/infrastructure-evidence.json"
        if evidence_path.is_file():
            errors.extend(_portal_infrastructure_evidence_errors(evidence_path))
    elif suite == "controller-e2e":
        evidence_path = (
            run_root / "controller-e2e/docker-snapshots/controller-environment.json"
        )
        if evidence_path.is_file():
            errors.extend(_controller_environment_evidence_errors(evidence_path))
    return errors


def _apply_evidence_failures(
    cases: list[dict[str, Any]],
    artifact_errors: list[str],
    secret_findings: list[str],
) -> None:
    by_id = {case["test_case_id"]: case for case in cases}
    reasons: dict[str, list[str]] = {}

    def add(case_ids: set[str], reason: str) -> None:
        for case_id in case_ids & set(by_id):
            case_reasons = reasons.setdefault(case_id, [])
            if reason not in case_reasons:
                case_reasons.append(reason)

    for error in artifact_errors:
        normalized_error = error.upper()
        direct = {
            case_id
            for case_id in by_id
            if error.startswith(f"{case_id} ") or case_id in normalized_error
        }
        if direct:
            add(direct, error)
        elif "portal-e2e/infrastructure-evidence.json" in error or error.startswith(
            "portal infrastructure evidence"
        ):
            add(set(_OUTER_EVIDENCE_FILES) - {"CONTROLLER-ENV-001"}, error)
        elif "controller-environment.json" in error or error.startswith(
            "controller environment evidence"
        ):
            add({"CONTROLLER-ENV-001"}, error)
        else:
            add({"ARTIFACT-001"}, error)
    if secret_findings:
        add(
            {"ARTIFACT-001", "RUNTIME-013"},
            "secret scan found: " + ",".join(secret_findings),
        )
    for case_id, case_reasons in reasons.items():
        case = by_id[case_id]
        case["status"] = "FAILED"
        evidence_detail = "; ".join(case_reasons)
        case["detail"] = "; ".join(
            item for item in (case["detail"], evidence_detail) if item
        )[:2000]


def _write_evidence_validation_failures(
    junit_paths: list[Path],
    cases: list[dict[str, Any]],
) -> None:
    failed = {
        case["test_case_id"]: case["detail"]
        for case in cases
        if case["status"] == "FAILED"
    }
    if not failed:
        return
    for path in junit_paths:
        try:
            tree = ET.parse(path)
        except (OSError, ET.ParseError):
            continue
        changed = False
        root = tree.getroot()
        for testcase in root.iter("testcase"):
            case_id = _properties(testcase).get("test_case_id")
            if (
                case_id not in failed
                or testcase.find("failure") is not None
                or testcase.find("error") is not None
            ):
                continue
            failure = ET.SubElement(
                testcase,
                "failure",
                type="EVIDENCE_VALIDATION_FAILURE",
                message="Frozen acceptance evidence validation failed",
            )
            failure.text = failed[case_id]
            changed = True
        if not changed:
            continue
        for suite in root.iter("testsuite"):
            direct = suite.findall("testcase")
            if direct:
                suite.set(
                    "failures",
                    str(sum(testcase.find("failure") is not None for testcase in direct)),
                )
        if root.tag == "testsuites":
            root.set(
                "failures",
                str(
                    sum(
                        int(suite.get("failures", "0"))
                        for suite in root.findall("testsuite")
                    )
                ),
            )
        tree.write(path, encoding="utf-8", xml_declaration=True)


def _stream_contains_secret(stream: BinaryIO, patterns: tuple[bytes, ...]) -> bool:
    overlap = max(len(pattern) for pattern in patterns) - 1
    trailing = b""
    while True:
        chunk = stream.read(65536)
        if not chunk:
            return False
        candidate = trailing + chunk
        if any(pattern in candidate for pattern in patterns):
            return True
        trailing = candidate[-overlap:] if overlap else b""


def _secret_scan(run_root: Path) -> list[str]:
    default_pattern = "TEST_SECRET_123456"
    configured = os.environ.get("TEST_SECRET_PATTERNS", default_pattern)
    values = [value for value in configured.split(",") if value]
    if not values:
        values = [default_pattern]
    patterns = tuple(value.encode("utf-8") for value in values)
    findings: list[str] = []
    for path in run_root.rglob("*"):
        if path.is_symlink() or not path.is_file() or path in {
            run_root / "summary.json",
            run_root / "summary.md",
        }:
            continue
        relative = str(path.relative_to(run_root))
        try:
            with path.open("rb") as handle:
                if _stream_contains_secret(handle, patterns):
                    findings.append(relative)
                    continue
        except OSError:
            findings.append(f"{relative}!<unreadable>")
            continue

        if path.suffix.lower() != ".zip":
            continue
        try:
            with zipfile.ZipFile(path) as archive:
                members = [item for item in archive.infolist() if not item.is_dir()]
                if len(members) > 10000 or sum(item.file_size for item in members) > 268435456:
                    findings.append(f"{relative}!<archive-scan-limit>")
                    continue
                for member in members:
                    if member.flag_bits & 0x1:
                        findings.append(f"{relative}!{member.filename}<encrypted>")
                        break
                    with archive.open(member) as handle:
                        if _stream_contains_secret(handle, patterns):
                            findings.append(f"{relative}!{member.filename}")
                            break
        except (OSError, RuntimeError, zipfile.BadZipFile):
            findings.append(f"{relative}!<invalid-archive>")
    return sorted(findings)


def _read_json_object(path: Path) -> tuple[dict[str, Any] | None, str | None]:
    try:
        document = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        return None, str(exc)
    if not isinstance(document, dict):
        return None, "root must be an object"
    return document, None


def _runtime_008_context_observation(
    context: dict[str, Any],
) -> tuple[str | None, str | None]:
    if context.get("test_case_id") != "RUNTIME-008":
        return None, "RUNTIME-008 Engine context Test Case ID is invalid"

    extended_fields = {
        "accepted_actions",
        "operation_actions",
        "engine_observation",
        "responses",
    }
    present_extended = extended_fields & set(context)
    if not present_extended:
        winner = context.get("winning_action")
        if winner in {"START", "STOP"}:
            return winner, None
        return None, "RUNTIME-008 Engine context observation is invalid"
    if present_extended != extended_fields:
        return None, "RUNTIME-008 Engine context is missing raw observation fields"

    accepted_actions = context.get("accepted_actions")
    operation_actions = context.get("operation_actions")
    responses = context.get("responses")
    if not all(
        isinstance(value, list)
        for value in (accepted_actions, operation_actions, responses)
    ):
        return None, "RUNTIME-008 Engine context raw observations are invalid"
    if len(responses) != 2:
        return None, "RUNTIME-008 Engine context must contain two API responses"

    response_actions: list[str] = []
    computed_accepted: list[str] = []
    computed_operations: list[str] = []
    has_error = False
    for response in responses:
        if not isinstance(response, dict):
            return None, "RUNTIME-008 Engine context response is invalid"
        action = response.get("action")
        status = response.get("http_status")
        operation_action = response.get("operation_action")
        error_class = response.get("error_class")
        if action not in {"START", "STOP"} or action in response_actions:
            return None, "RUNTIME-008 Engine context response actions are invalid"
        response_actions.append(action)
        if error_class is not None:
            if not isinstance(error_class, str) or not error_class:
                return None, "RUNTIME-008 Engine context response error is invalid"
            if status is not None or operation_action is not None:
                return None, "RUNTIME-008 Engine context error response is contradictory"
            has_error = True
            continue
        if isinstance(status, bool) or not isinstance(status, int):
            return None, "RUNTIME-008 Engine context response status is invalid"
        if operation_action is not None and operation_action not in {"START", "STOP"}:
            return None, "RUNTIME-008 Engine context operation action is invalid"
        if status < 300:
            computed_accepted.append(action)
        if operation_action == action:
            computed_operations.append(action)

    if accepted_actions != computed_accepted or operation_actions != computed_operations:
        return None, "RUNTIME-008 Engine context derived observations are inconsistent"
    if has_error:
        expected_observation = "UNRESOLVED"
    elif len(computed_operations) == 1:
        expected_observation = computed_operations[0]
    elif not computed_operations and len(computed_accepted) == 1:
        expected_observation = computed_accepted[0]
    elif computed_operations:
        expected_observation = "MULTIPLE"
    else:
        expected_observation = "NONE"
    expected_winner = (
        expected_observation
        if expected_observation in {"START", "STOP"}
        else None
    )
    if context.get("engine_observation") != expected_observation:
        return None, "RUNTIME-008 Engine context observation is inconsistent"
    if context.get("winning_action") != expected_winner:
        return None, "RUNTIME-008 Engine context winner is inconsistent"
    return expected_observation, None


def _write_summary(run_root: Path, summary: dict[str, Any]) -> None:
    (run_root / "summary.json").write_text(
        json.dumps(summary, ensure_ascii=False, indent=2) + "\n", encoding="utf-8"
    )
    counts = summary["counts"]
    lines = [
        f"# Hermes E2E Summary — {summary['run_id']}",
        "",
        f"Overall: **{summary['status']}**",
        "",
        f"- Passed: {counts['passed']}",
        f"- Failed: {counts['failed']}",
        f"- Blocked by contract: {counts.get('blocked_by_contract', 0)}",
        f"- Skipped: {counts['skipped']}",
        f"- Not evaluated: {counts['not_evaluated']}",
    ]
    if "deferred_by_milestone" in counts:
        lines.append(
            f"- Deferred by milestone: {counts['deferred_by_milestone']}"
        )
    lines.extend(
        [
            "- Critical not passed: "
            + (", ".join(summary["critical_not_passed"]) or "none"),
            "- Metadata errors: "
            + (", ".join(summary["metadata_errors"]) or "none"),
            "- Manifest errors: "
            + (", ".join(summary["manifest_errors"]) or "none"),
            "- Inventory errors: "
            + (", ".join(summary["inventory_errors"]) or "none"),
            "- Artifact errors: "
            + (", ".join(summary["artifact_errors"]) or "none"),
            "- Secret findings: "
            + (", ".join(summary["secret_findings"]) or "none"),
            "",
            "| Test Case ID | Requirement IDs | Execution | Acceptance | Coverage claim |",
            "|---|---|---|---|---|",
        ]
    )
    for case in summary["cases"]:
        lines.append(
            f"| {case['test_case_id']} | {', '.join(case['requirement_ids'])} | "
            f"{case['execution_status']} | {case['status']} | {case['coverage_claim']} |"
        )
    (run_root / "summary.md").write_text("\n".join(lines) + "\n", encoding="utf-8")


def _deferred_case(case_id: str, junit_source: Path) -> dict[str, Any]:
    requirement_ids, critical = _DEFERRED_CASES[case_id]
    return {
        "test_case_id": case_id,
        "requirement_ids": list(requirement_ids),
        "critical": critical,
        "critical_metadata": str(critical).lower(),
        "status": "DEFERRED_BY_MILESTONE",
        "execution_status": "SKIPPED",
        "case_source": (
            "test-cases/control-wafer/cases.yaml"
            if case_id.startswith("CW-")
            else "test-cases/deployment-check/cases.yaml"
        ),
        "coverage_claim": "deferred-by-milestone",
        "acceptance_status": "deferred-by-milestone",
        "golden_status": "not-executed",
        "evidence_kind": "milestone-deferral",
        "engine_evidence": None,
        "engine_evidence_file": None,
        "outer_evidence": None,
        "outer_evidence_file": None,
        "failure_classification": "",
        "name": f"{case_id} deferred to T-M4",
        "classname": "hermes.acceptance.deferred.t_m4",
        "duration_seconds": 0.0,
        "detail": "DEFERRED_BY_MILESTONE: T-M4; Expected Result was not evaluated.",
        "junit_source": str(junit_source),
    }


def _deferred_testcase(case_id: str) -> ET.Element:
    requirement_ids, critical = _DEFERRED_CASES[case_id]
    testcase = ET.Element(
        "testcase",
        classname="hermes.acceptance.deferred.t_m4",
        name=f"{case_id} deferred to T-M4",
        time="0",
    )
    properties = ET.SubElement(testcase, "properties")
    for name, value in (
        ("test_case_id", case_id),
        ("requirement_ids", ",".join(requirement_ids)),
        ("critical", str(critical).lower()),
        ("milestone", "T-M4"),
        ("hermes.classification", "DEFERRED_BY_MILESTONE"),
    ):
        ET.SubElement(properties, "property", name=name, value=value)
    ET.SubElement(
        testcase,
        "skipped",
        message="DEFERRED_BY_MILESTONE: T-M4; Expected Result was not evaluated",
    )
    return testcase


def _missing_frozen_case(case_id: str, junit_source: Path) -> dict[str, Any]:
    is_runtime = case_id.startswith("RUNTIME-")
    return {
        "test_case_id": case_id,
        "requirement_ids": list(_CASE_REQUIREMENTS[case_id]),
        "critical": True,
        "critical_metadata": "true",
        "status": "FAILED",
        "execution_status": "FAILED",
        "case_source": (
            "frozen-runtime-case" if is_runtime else "frozen-infrastructure-case"
        ),
        "coverage_claim": "none",
        "acceptance_status": "test-not-implemented",
        "golden_status": "frozen-v0.2.0",
        "evidence_kind": "missing-test-evidence",
        "engine_evidence": None,
        "engine_evidence_file": None,
        "outer_evidence": None,
        "outer_evidence_file": None,
        "failure_classification": "BLOCKED_BY_ENVIRONMENT",
        "name": f"{case_id} missing Frozen acceptance evidence",
        "classname": "hermes.acceptance.missing_frozen_case",
        "duration_seconds": 0.0,
        "detail": (
            "BLOCKED_BY_ENVIRONMENT: canonical child execution evidence is "
            "missing after orchestration."
        ),
        "junit_source": str(junit_source),
    }


def _missing_frozen_testcase(case_id: str) -> ET.Element:
    testcase = ET.Element(
        "testcase",
        classname="hermes.acceptance.missing_frozen_case",
        name=f"{case_id} missing Frozen acceptance evidence",
        time="0",
    )
    properties = ET.SubElement(testcase, "properties")
    for name, value in (
        ("test_case_id", case_id),
        ("requirement_ids", ",".join(_CASE_REQUIREMENTS[case_id])),
        ("critical", "true"),
        ("failure_classification", "BLOCKED_BY_ENVIRONMENT"),
    ):
        ET.SubElement(properties, "property", name=name, value=value)
    ET.SubElement(
        testcase,
        "failure",
        type="BLOCKED_BY_ENVIRONMENT",
        message="canonical child execution evidence is missing after orchestration",
    )
    return testcase


def _child_evidence(
    run_root: Path,
    expected_suite: str,
) -> tuple[
    dict[str, Any] | None,
    dict[str, tuple[dict[str, Any], ET.Element]],
    list[str],
    list[str],
    list[str],
    list[str],
    list[str],
    list[str],
]:
    manifest, manifest_read_error = _read_json_object(run_root / "manifest.yaml")
    manifest_errors = _manifest_errors(run_root, run_root.name)
    if manifest_read_error and not manifest_errors:
        manifest_errors.append(f"manifest.yaml: {manifest_read_error}")
    if manifest is not None and manifest.get("test_suite") != expected_suite:
        manifest_errors.append(
            f"child {run_root.name} must be suite {expected_suite!r}"
        )

    parse_errors: list[str] = []
    case_entries: dict[str, tuple[dict[str, Any], ET.Element]] = {}
    junit_root = run_root / "junit"
    junit_paths = sorted(
        path for path in junit_root.glob("*.xml") if path.is_file() and not path.is_symlink()
    )
    if not junit_paths:
        parse_errors.append(f"{run_root.name}: canonical JUnit is missing")
    cases: list[dict[str, Any]] = []
    for path in junit_paths:
        try:
            root = ET.parse(path).getroot()
            for testcase in root.iter("testcase"):
                case = _case_result(
                    testcase,
                    Path(run_root.name) / path.relative_to(run_root),
                )
                cases.append(case)
                case_id = case["test_case_id"]
                if case_id not in case_entries:
                    case_entries[case_id] = (case, testcase)
        except (ET.ParseError, OSError, ValueError) as exc:
            parse_errors.append(f"{run_root.name}/{path.relative_to(run_root)}: {exc}")

    metadata_errors = [error for case in cases for error in _metadata_errors(case)]
    inventory_errors = _inventory_errors(run_root, cases)
    artifact_errors = _artifact_errors(run_root, cases)
    secret_findings = _secret_scan(run_root)
    _apply_evidence_failures(cases, artifact_errors, secret_findings)
    summary, summary_error = _read_json_object(run_root / "summary.json")
    if summary_error:
        artifact_errors.append(f"{run_root.name}/summary.json: {summary_error}")
    elif summary is not None:
        hard_failure = bool(
            parse_errors
            or metadata_errors
            or manifest_errors
            or inventory_errors
            or artifact_errors
            or secret_findings
            or any(case["status"] == "FAILED" for case in cases)
        )
        expected_status = (
            "FAIL"
            if hard_failure
            else "CONTRACT_BLOCKED"
            if any(case["status"] == "BLOCKED_BY_CONTRACT" for case in cases)
            else "PASS"
        )
        if summary.get("status") != expected_status:
            artifact_errors.append(
                f"child {run_root.name} summary status must equal "
                f"{expected_status!r}"
            )
    return (
        manifest,
        case_entries,
        parse_errors,
        metadata_errors,
        manifest_errors,
        inventory_errors,
        artifact_errors,
        [f"{run_root.name}/{finding}" for finding in secret_findings],
    )


def _master_main(
    results_root: Path,
    master_run_id: str,
    infrastructure_run_id: str,
    runtime_run_id: str,
) -> int:
    run_ids = (master_run_id, infrastructure_run_id, runtime_run_id)
    if any(not _RUN_ID.fullmatch(run_id) for run_id in run_ids):
        print("run-id contains unsupported characters", file=sys.stderr)
        return 80
    if len(set(run_ids)) != len(run_ids):
        print("master and child run IDs must be distinct", file=sys.stderr)
        return 80

    infrastructure_root = results_root / infrastructure_run_id
    runtime_root = results_root / runtime_run_id
    if not infrastructure_root.is_dir() or not runtime_root.is_dir():
        print("master child run directory not found", file=sys.stderr)
        return 80
    (
        infrastructure_manifest,
        infrastructure_entries,
        infrastructure_parse,
        infrastructure_metadata,
        infrastructure_manifest_errors,
        infrastructure_inventory,
        infrastructure_artifact,
        infrastructure_secrets,
    ) = _child_evidence(infrastructure_root, "portal-e2e")
    (
        runtime_manifest,
        runtime_entries,
        runtime_parse,
        runtime_metadata,
        runtime_manifest_errors,
        runtime_inventory,
        runtime_artifact,
        runtime_secrets,
    ) = _child_evidence(runtime_root, "controller-e2e")

    parse_errors = infrastructure_parse + runtime_parse
    metadata_errors = infrastructure_metadata + runtime_metadata
    manifest_errors = infrastructure_manifest_errors + runtime_manifest_errors
    inventory_errors = infrastructure_inventory + runtime_inventory
    artifact_errors = infrastructure_artifact + runtime_artifact
    secret_findings = infrastructure_secrets + runtime_secrets
    child_manifests = [
        manifest
        for manifest in (infrastructure_manifest, runtime_manifest)
        if manifest is not None
    ]
    for field in ("git_commit", "git_branch", "platform_commit", "contract_tag", "contract_commit", "contract_version"):
        values = {manifest.get(field) for manifest in child_manifests}
        if len(child_manifests) == 2 and len(values) != 1:
            manifest_errors.append(f"child manifests disagree on {field}")
    if len(child_manifests) == 2:
        infrastructure_images = infrastructure_manifest.get("images", {})
        runtime_images = runtime_manifest.get("images", {})
        infrastructure_image_ids = infrastructure_manifest.get("image_ids", {})
        runtime_image_ids = runtime_manifest.get("image_ids", {})
        if all(
            isinstance(value, dict)
            for value in (
                infrastructure_images,
                runtime_images,
                infrastructure_image_ids,
                runtime_image_ids,
            )
        ):
            shared_roles = sorted(
                set(infrastructure_images)
                & set(runtime_images)
                & set(infrastructure_image_ids)
                & set(runtime_image_ids)
            )
            for role in shared_roles:
                if infrastructure_images.get(role) != runtime_images.get(role):
                    manifest_errors.append(
                        f"child manifests disagree on images.{role}"
                    )
                if infrastructure_image_ids.get(role) != runtime_image_ids.get(role):
                    manifest_errors.append(
                        f"child manifests disagree on image_ids.{role}"
                    )

    combined_entries = {**infrastructure_entries, **runtime_entries}
    counts_by_id = Counter(
        [*infrastructure_entries.keys(), *runtime_entries.keys()]
    )
    missing = [case_id for case_id in _FROZEN_CASE_ORDER if case_id not in combined_entries]
    unexpected = sorted(set(combined_entries) - set(_FROZEN_CASE_ORDER))
    duplicates = sorted(case_id for case_id, count in counts_by_id.items() if count != 1)
    if missing:
        inventory_errors.append(
            "master inventory is missing frozen cases: " + ",".join(missing)
        )
    if unexpected:
        inventory_errors.append(
            "master inventory has unexpected frozen cases: " + ",".join(unexpected)
        )
    if duplicates:
        inventory_errors.append(
            "master inventory has duplicate frozen cases: " + ",".join(duplicates)
        )

    master_root = results_root / master_run_id
    junit_root = master_root / "junit"
    junit_root.mkdir(parents=True, exist_ok=True)
    master_junit_relative = Path("junit/m0-m1-acceptance.xml")
    frozen_rows: list[tuple[dict[str, Any], ET.Element]] = []
    for case_id in _FROZEN_CASE_ORDER:
        entry = combined_entries.get(case_id)
        if entry is None:
            entry = (
                _missing_frozen_case(case_id, master_junit_relative),
                _missing_frozen_testcase(case_id),
            )
        frozen_rows.append(entry)
    cases: list[dict[str, Any]] = [case for case, _testcase in frozen_rows]
    _apply_evidence_failures(
        cases,
        [
            *artifact_errors,
            *parse_errors,
            *metadata_errors,
            *manifest_errors,
            *inventory_errors,
        ],
        secret_findings,
    )
    suite = ET.Element(
        "testsuite",
        name="hermes.m0-m1.acceptance.v0.2.0",
        tests="31",
        skipped=str(len(_DEFERRED_CASES)),
    )
    for case, testcase in frozen_rows:
        if (
            case["status"] == "FAILED"
            and testcase.find("failure") is None
            and testcase.find("error") is None
        ):
            failure = ET.SubElement(
                testcase,
                "failure",
                type="EVIDENCE_VALIDATION_FAILURE",
                message="Frozen acceptance evidence validation failed",
            )
            failure.text = case["detail"]
        suite.append(testcase)
    for case_id in _DEFERRED_CASES:
        suite.append(_deferred_testcase(case_id))
        cases.append(_deferred_case(case_id, master_junit_relative))
    suite.set(
        "failures",
        str(sum(testcase.find("failure") is not None for testcase in suite.findall("testcase"))),
    )
    suite.set(
        "errors",
        str(sum(testcase.find("error") is not None for testcase in suite.findall("testcase"))),
    )
    suite.set(
        "skipped",
        str(sum(testcase.find("skipped") is not None for testcase in suite.findall("testcase"))),
    )
    suite.set(
        "time",
        f"{sum(case['duration_seconds'] for case in cases):.6f}",
    )
    ET.ElementTree(suite).write(
        master_root / master_junit_relative,
        encoding="utf-8",
        xml_declaration=True,
    )

    first_manifest = child_manifests[0] if child_manifests else {}
    images: dict[str, Any] = {}
    image_ids: dict[str, Any] = {}
    for manifest in child_manifests:
        images.update(manifest.get("images", {}))
        image_ids.update(manifest.get("image_ids", {}))
    master_manifest = {
        "run_id": master_run_id,
        "fixture_type": "SYNTHETIC",
        "spec_version": "0.1.0",
        "contract_tag": _FROZEN_CONTRACT_TAG,
        "contract_commit": _FROZEN_CONTRACT_COMMIT,
        "contract_version": _FROZEN_CONTRACT_VERSION,
        "git_commit": first_manifest.get("git_commit", ""),
        "git_branch": first_manifest.get("git_branch", ""),
        "platform_commit": first_manifest.get("platform_commit", ""),
        "test_suite": "m0-m1-acceptance",
        "child_runs": {
            "infrastructure": infrastructure_run_id,
            "runtime": runtime_run_id,
        },
        "images": images,
        "image_ids": image_ids,
        "executed_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }
    (master_root / "manifest.yaml").write_text(
        json.dumps(master_manifest, ensure_ascii=False, indent=2) + "\n",
        encoding="utf-8",
    )

    counts = {
        "total": len(cases),
        "passed": sum(case["status"] == "PASSED" for case in cases),
        "failed": sum(case["status"] == "FAILED" for case in cases),
        "blocked_by_contract": sum(
            case["status"] == "BLOCKED_BY_CONTRACT" for case in cases
        ),
        "skipped": sum(case["execution_status"] == "SKIPPED" for case in cases),
        "not_evaluated": sum(case["status"] == "NOT_EVALUATED" for case in cases),
        "deferred_by_milestone": sum(
            case["status"] == "DEFERRED_BY_MILESTONE" for case in cases
        ),
    }
    critical_not_passed = sorted(
        case["test_case_id"]
        for case in cases
        if case["critical"]
        and case["status"] not in {"PASSED", "DEFERRED_BY_MILESTONE"}
    )
    frozen_hard_not_passed = sorted(
        case["test_case_id"]
        for case in cases
        if case["test_case_id"] in _FROZEN_CASE_ORDER
        and case["status"] not in {"PASSED", "BLOCKED_BY_CONTRACT"}
    )
    status = "PASS"
    if (
        len(cases) != 31
        or parse_errors
        or metadata_errors
        or manifest_errors
        or inventory_errors
        or artifact_errors
        or secret_findings
        or frozen_hard_not_passed
        or counts["not_evaluated"]
    ):
        status = "FAIL"
    elif counts["blocked_by_contract"]:
        status = "CONTRACT_BLOCKED"
    summary = {
        "schema_version": "0.2.0",
        "role": "independent-test-implementer",
        "run_id": master_run_id,
        "status": status,
        "fixture_type": "SYNTHETIC",
        "counts": counts,
        "critical_not_passed": critical_not_passed,
        "cases": cases,
        "junit_files": [str(master_junit_relative)],
        "manifest_file": "manifest.yaml",
        "parse_errors": parse_errors,
        "metadata_errors": metadata_errors,
        "manifest_errors": manifest_errors,
        "inventory_errors": inventory_errors,
        "artifact_errors": artifact_errors,
        "secret_findings": secret_findings,
    }
    _write_summary(master_root, summary)
    print(f"wrote {master_root / 'summary.json'}")
    print(f"wrote {master_root / 'summary.md'}")
    return 0 if status == "PASS" else 80


def main() -> int:
    repo_root = Path(__file__).resolve().parent.parent
    results_root = Path(os.environ.get("TEST_RESULTS_ROOT", repo_root / "test-results")).resolve()
    if len(sys.argv) == 5 and sys.argv[1] == "--master":
        return _master_main(results_root, sys.argv[2], sys.argv[3], sys.argv[4])
    if len(sys.argv) != 2:
        print(
            "usage: scripts/collect-test-results <run-id>\n"
            "       scripts/collect-test-results --master "
            "<master-run-id> <infrastructure-run-id> <runtime-run-id>",
            file=sys.stderr,
        )
        return 80

    run_id = sys.argv[1]
    if not _RUN_ID.fullmatch(run_id):
        print("run-id contains unsupported characters", file=sys.stderr)
        return 80
    run_root = results_root / run_id
    if not run_root.is_dir():
        print(f"run directory not found: {run_root}", file=sys.stderr)
        return 80

    cases: list[dict[str, Any]] = []
    parse_errors: list[str] = []
    junit_paths = _canonical_junit_paths(run_root)
    for path in junit_paths:
        try:
            root = ET.parse(path).getroot()
            for testcase in root.iter("testcase"):
                cases.append(_case_result(testcase, path.relative_to(run_root)))
        except (ET.ParseError, OSError, ValueError) as exc:
            parse_errors.append(f"{path.relative_to(run_root)}: {exc}")

    metadata_errors = [error for case in cases for error in _metadata_errors(case)]
    manifest_errors = _manifest_errors(run_root, run_id)
    inventory_errors = _inventory_errors(run_root, cases)
    artifact_errors = _artifact_errors(run_root, cases)

    secret_findings = _secret_scan(run_root)
    _apply_evidence_failures(cases, artifact_errors, secret_findings)
    _write_evidence_validation_failures(junit_paths, cases)
    counts = {
        "total": len(cases),
        "passed": sum(case["status"] == "PASSED" for case in cases),
        "failed": sum(case["status"] == "FAILED" for case in cases),
        "blocked_by_contract": sum(
            case["status"] == "BLOCKED_BY_CONTRACT" for case in cases
        ),
        "skipped": sum(case["execution_status"] == "SKIPPED" for case in cases),
        "not_evaluated": sum(case["status"] == "NOT_EVALUATED" for case in cases),
    }
    critical_not_passed = [
        case["test_case_id"]
        for case in cases
        if case["critical"] and case["status"] != "PASSED"
    ]
    critical_hard_not_passed = [
        case["test_case_id"]
        for case in cases
        if case["critical"]
        and case["status"] not in {"PASSED", "BLOCKED_BY_CONTRACT"}
    ]
    status = "PASS"
    if (
        not junit_paths
        or not cases
        or parse_errors
        or metadata_errors
        or manifest_errors
        or inventory_errors
        or artifact_errors
        or secret_findings
        or counts["failed"]
        or critical_hard_not_passed
    ):
        status = "FAIL"
    elif counts["blocked_by_contract"]:
        status = "CONTRACT_BLOCKED"
    elif cases and all(case["status"] == "NOT_EVALUATED" for case in cases):
        status = "INFRA_PASS"

    summary = {
        "schema_version": "0.2.0",
        "role": "independent-test-implementer",
        "run_id": run_id,
        "status": status,
        "fixture_type": "SYNTHETIC",
        "counts": counts,
        "critical_not_passed": sorted(set(critical_not_passed)),
        "cases": cases,
        "junit_files": [str(path.relative_to(run_root)) for path in junit_paths],
        "manifest_file": "manifest.yaml",
        "parse_errors": parse_errors,
        "metadata_errors": metadata_errors,
        "manifest_errors": manifest_errors,
        "inventory_errors": inventory_errors,
        "artifact_errors": artifact_errors,
        "secret_findings": secret_findings,
    }
    _write_summary(run_root, summary)

    print(f"wrote {run_root / 'summary.json'}")
    print(f"wrote {run_root / 'summary.md'}")
    return 0 if status in {"PASS", "INFRA_PASS"} else 80


if __name__ == "__main__":
    raise SystemExit(main())
