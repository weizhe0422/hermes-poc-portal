{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/hermes-poc/tests/summary.schema.json",
  "title": "HermesTestRunSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "role",
    "run_id",
    "status",
    "fixture_type",
    "counts",
    "critical_not_passed",
    "cases",
    "junit_files",
    "manifest_file",
    "parse_errors",
    "metadata_errors",
    "manifest_errors",
    "inventory_errors",
    "artifact_errors",
    "secret_findings"
  ],
  "properties": {
    "schema_version": {"const": "0.2.0"},
    "role": {"const": "independent-test-implementer"},
    "run_id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["PASS", "INFRA_PASS", "FAIL", "CONTRACT_BLOCKED"]
    },
    "fixture_type": {"const": "SYNTHETIC"},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "skipped", "not_evaluated"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "skipped": {"type": "integer", "minimum": 0},
        "not_evaluated": {"type": "integer", "minimum": 0},
        "blocked_by_contract": {"type": "integer", "minimum": 0},
        "deferred_by_milestone": {"type": "integer", "minimum": 0}
      }
    },
    "critical_not_passed": {"type": "array", "items": {"type": "string"}},
    "cases": {
      "type": "array",
      "items": {"$ref": "#/$defs/case"}
    },
    "junit_files": {"type": "array", "items": {"type": "string"}},
    "manifest_file": {"const": "manifest.yaml"},
    "parse_errors": {"type": "array", "items": {"type": "string"}},
    "metadata_errors": {"type": "array", "items": {"type": "string"}},
    "manifest_errors": {"type": "array", "items": {"type": "string"}},
    "inventory_errors": {"type": "array", "items": {"type": "string"}},
    "artifact_errors": {"type": "array", "items": {"type": "string"}},
    "secret_findings": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_case_id",
        "requirement_ids",
        "critical",
        "critical_metadata",
        "status",
        "execution_status",
        "case_source",
        "coverage_claim",
        "acceptance_status",
        "golden_status",
        "evidence_kind",
        "engine_evidence",
        "engine_evidence_file",
        "outer_evidence",
        "outer_evidence_file",
        "failure_classification",
        "name",
        "classname",
        "duration_seconds",
        "detail",
        "junit_source"
      ],
      "properties": {
        "test_case_id": {"type": "string", "minLength": 1},
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "critical": {"type": "boolean"},
        "critical_metadata": {"type": "string"},
        "status": {
          "type": "string",
          "enum": [
            "PASSED",
            "FAILED",
            "SKIPPED",
            "NOT_EVALUATED",
            "BLOCKED_BY_CONTRACT",
            "DEFERRED_BY_MILESTONE"
          ]
        },
        "execution_status": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "SKIPPED"]
        },
        "case_source": {"type": "string"},
        "coverage_claim": {"type": "string"},
        "acceptance_status": {"type": "string"},
        "golden_status": {"type": "string"},
        "evidence_kind": {"type": "string"},
        "engine_evidence": {"type": ["string", "null"]},
        "engine_evidence_file": {"type": ["string", "null"]},
        "outer_evidence": {"type": ["string", "null"]},
        "outer_evidence_file": {"type": ["string", "null"]},
        "failure_classification": {"type": "string"},
        "name": {"type": "string"},
        "classname": {"type": "string"},
        "duration_seconds": {"type": "number", "minimum": 0},
        "detail": {"type": "string"},
        "junit_source": {"type": "string"}
      }
    }
  }
}
