{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/hermes-poc/tests/manifest.schema.json",
  "title": "HermesTestRunManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "fixture_type",
    "spec_version",
    "contract_tag",
    "contract_commit",
    "contract_version",
    "git_commit",
    "git_branch",
    "platform_commit",
    "test_commit",
    "test_suite",
    "images",
    "image_ids",
    "executed_at"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9_-]{0,61}[a-z0-9])?$",
      "maxLength": 63
    },
    "fixture_type": {"const": "SYNTHETIC"},
    "spec_version": {"const": "0.1.0"},
    "contract_tag": {"const": "contract-m0-m1-v0.2.1"},
    "contract_commit": {
      "const": "febdea906a51bab59e582755c495ed2253fb64b8"
    },
    "contract_version": {"const": "0.2.1"},
    "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "git_branch": {"type": ["string", "null"], "minLength": 1},
    "platform_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "test_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "test_suite": {
      "type": "string",
      "enum": ["controller-e2e", "portal-e2e", "m0-m1-acceptance"]
    },
    "child_runs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["infrastructure", "runtime"],
      "properties": {
        "infrastructure": {"type": "string", "minLength": 1},
        "runtime": {"type": "string", "minLength": 1}
      }
    },
    "images": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "image_ids": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      }
    },
    "executed_at": {"type": "string", "format": "date-time"}
  }
}
