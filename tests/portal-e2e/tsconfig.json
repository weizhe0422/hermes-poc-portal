{
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "playwright.config.ts",
    "reporters/**/*.ts",
    "probes/**/*.ts",
    "support/**/*.ts",
    "tests/**/*.ts",
    "unit/**/*.ts"
  ]
}
