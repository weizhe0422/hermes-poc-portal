# 依 contracts/environment.yaml 定義；不得將真實 Secret 提交至版本庫（docs/04）。
# Secret 值一律留空，Runtime 以環境注入。

PORTAL_PORT=8080
PORTAL_DATABASE_URL=sqlite:////data/portal.db
DEFAULT_INSTANCE_ID=hermes-poc-001
CONTROLLER_BASE_URL=http://controller:8090
HERMES_BASE_URL=http://hermes:8000
HERMES_HEALTH_PATH=/health
HERMES_LLM_BASE_URL=
HERMES_LLM_API_KEY=
HERMES_MODEL_NAME=
HERMES_START_TIMEOUT_SECONDS=120
HERMES_STOP_TIMEOUT_SECONDS=30
AGENT_REQUEST_TIMEOUT_SECONDS=90
CONTROLLER_MANAGED_LABEL=poc.managed=true
LOG_LEVEL=INFO
SPEC_VERSION=0.1.0

# --- Compose 部署層變數（非 environment.yaml 應用變數） ---
# OD-01 Blocker：實際 Hermes Image tag/digest 未定，必填、不得假設。
# 本機整合驗證時可暫指向 hermes-poc-hermes-fixture:dev。
HERMES_IMAGE=
# 方案 A：socket 只掛給 Controller；Linux Host 需設 docker group GID 讓非 root
# Controller 使用者可存取 socket（macOS Docker Desktop 可留 0）。
DOCKER_GID=0
