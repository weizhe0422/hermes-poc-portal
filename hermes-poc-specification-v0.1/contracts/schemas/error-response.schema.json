{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/hermes-poc/schemas/error-response.schema.json",
  "$comment": "文件目的：定義Portal及Controller所有受控錯誤回應，避免洩漏Stack Trace、Docker Socket或敏感內部資訊。",
  "title": "ErrorResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["error_code", "message", "correlation_id", "retryable"],
  "properties": {
    "error_code": {"type": "string", "minLength": 1},
    "message": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "retryable": {"type": "boolean"},
    "details": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    }
  }
}
